# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# Admin authentication secret (users send /admin <secret> to become admin)
ADMIN_SECRET=

# Database path (optional, default: bot.db)
# DB_PATH=bot.db

# Telegram Bot API Local Server (optional, for large file support >20MB)
# API_BASE_URL=http://localhost:8081/bot
# API_BASE_FILE_URL=http://localhost:8081/file/bot
